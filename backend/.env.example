# Server
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# JWT — required for wallet auth (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret_string

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Users table — run backend/supabase/schema.sql in Supabase SQL Editor
SUPABASE_USERS_TABLE=users

# Optional DB connection test table
# SUPABASE_TEST_TABLE=health_checks
