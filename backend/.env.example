# Server
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# JWT — required for wallet auth (use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret_string

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# SkillBadge contract (after deploy — see contracts/)
# CONTRACT_ADDRESS=0xYourDeployedAddress

# Supabase — Project Settings → API (service role key on backend only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Legacy alias (also supported)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Users table — run backend/supabase/migrations/001_users_siwe.sql
SUPABASE_USERS_TABLE=users

# Optional DB connection test table
# SUPABASE_TEST_TABLE=health_checks
