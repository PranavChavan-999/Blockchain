# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:5000

# WalletConnect Cloud project ID — https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: show Aave Account in ConnectKit (default off — use MetaMask for hackathon)
# VITE_ENABLE_AAVE_ACCOUNT=true

# Deployed SkillBadge contract on Base Sepolia (required for claims)
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Optional: override RPC (dev defaults to /rpc/base-sepolia via Vite proxy)
# VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
